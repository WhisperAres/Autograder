# PostgreSQL Database Configuration
# For local development (uncomment and fill in):
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=autograder_db
# DB_USER=your_db_username
# DB_PASSWORD=your_db_password

# For production/cloud DB (recommended for deployment):
DATABASE_URL=postgresql://your_db_username:your_db_password@your_db_host:5432/your_db_name

# Server Configuration
PORT=5000
NODE_ENV=production  # Change to 'development' for local dev

# JWT Secret (generate a strong random string, e.g., via openssl rand -hex 32)
JWT_SECRET=your_strong_random_jwt_secret_here
JWT_EXPIRATION=30d

# Email service (if using Brevo or similar; see BREVO_SETUP.md for details)
# Add any other email/API keys here as needed